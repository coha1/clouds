[gd_scene load_steps=2 format=3 uid="uid://clouds_hud"]

[ext_resource type="Script" path="res://scenes/ui/hud.gd" id="1_hud"]

; ─────────────────────────────────────────────────────────────────────────────

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1_hud")

; Flight info — top-left corner
[node name="FlightInfo" type="VBoxContainer" parent="."]
offset_left = 20.0
offset_top = 20.0
theme_override_constants/separation = 4

[node name="SpeedLabel" type="Label" parent="FlightInfo"]
unique_name_in_owner = true
text = "SPD  -- m/s"
theme_override_colors/font_color = Color(1, 1, 1, 0.9)
theme_override_font_sizes/font_size = 18

[node name="AltLabel" type="Label" parent="FlightInfo"]
unique_name_in_owner = true
text = "ALT  -- m"
theme_override_colors/font_color = Color(1, 1, 1, 0.9)
theme_override_font_sizes/font_size = 18

[node name="ThrottleLabel" type="Label" parent="FlightInfo"]
unique_name_in_owner = true
text = "THR  --%"
theme_override_colors/font_color = Color(1, 1, 1, 0.9)
theme_override_font_sizes/font_size = 18

; Land / take-off prompt — bottom-centre, shown by landing_zone.gd via group
[node name="LandPrompt" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -160.0
offset_top = -160.0
offset_right = 160.0
offset_bottom = -120.0
horizontal_alignment = 1
theme_override_colors/font_color = Color(0.4, 1.0, 0.55, 1.0)
theme_override_font_sizes/font_size = 22
visible = false

; Stall warning — screen-center, hidden until stall
[node name="StallLabel" type="Label" parent="."]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -80.0
offset_top = -20.0
offset_right = 80.0
offset_bottom = 20.0
text = "⚠  STALL"
horizontal_alignment = 1
theme_override_colors/font_color = Color(1.0, 0.3, 0.2, 1.0)
theme_override_font_sizes/font_size = 28
visible = false
