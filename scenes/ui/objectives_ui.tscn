[gd_scene format=3 uid="uid://objectives_ui"]

[ext_resource type="Script" path="res://scenes/ui/objectives_ui.gd" id="1_obj"]

[sub_resource type="StyleBoxFlat" id="Style_panel"]
bg_color = Color(0.04, 0.07, 0.13, 0.72)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8

; =============================================================================

[node name="ObjectivesUI" type="CanvasLayer"]
layer = 5
script = ExtResource("1_obj")

; Anchored to top-right; grows downward as quests are added.
[node name="Panel" type="PanelContainer" parent="."]
anchor_left = 1.0
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 0.0
offset_left = -220.0
offset_top = 12.0
offset_right = -12.0
offset_bottom = 12.0
grow_horizontal = 0
theme_override_styles/panel = SubResource("Style_panel")

[node name="Margin" type="MarginContainer" parent="Panel"]
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 10
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 10

[node name="VBox" type="VBoxContainer" parent="Panel/Margin"]
theme_override_constants/separation = 4

[node name="Header" type="Label" parent="Panel/Margin/VBox"]
text = "OBJECTIVES"
horizontal_alignment = 2
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(0.55, 0.7, 0.9, 0.6)

[node name="QuestList" type="VBoxContainer" parent="Panel/Margin/VBox"]
unique_name_in_owner = true
theme_override_constants/separation = 3
